# Database
DATABASE_URL=postgresql://padvik:Talipot@123@localhost:5432/padvik

# Redis (use Upstash URL for cloud, or local Redis)
REDIS_URL=redis://localhost:6379

# Auth.js
NEXTAUTH_SECRET=change-me-in-production
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (for Auth.js Google provider)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Anthropic (Primary AI provider)
ANTHROPIC_API_KEY=

# OpenAI (Fallback AI provider)
OPENAI_API_KEY=

# Google Gemini
GOOGLE_GENERATIVE_AI_API_KEY=

# Mistral — Bulk generation (cheapest)
MISTRAL_API_KEY=

# Perplexity — Web search for current affairs
PERPLEXITY_API_KEY=

# Sarvam AI — Indic language OCR specialist (91-95% accuracy on Hindi, Tamil, Malayalam)
SARVAM_API_KEY=

# YouTube Data API v3 — for video search and suggestions
# Get from: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# AWS S3 (File storage — Mumbai region)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=padvik-uploads
AWS_REGION=ap-south-1

# Frontend feature flag — set to "true" to use real APIs instead of mock data
NEXT_PUBLIC_API_READY=true

# OTP Provider (for phone auth — add later)
# MSG91_AUTH_KEY=
# MSG91_TEMPLATE_ID=

# Auto Content Pipeline
PADVIK_SYSTEM_CREATOR_ID=6
DAILY_CONTENT_BUDGET=5.00
AUTO_CONTENT_ENABLED=true

# Auto-content model overrides (optional). Defaults: Opus 4.8 for notes &
# question sets, Sonnet 4.6 for the audio script, Haiku 4.5 for video re-rank.
# AUTO_CONTENT_EFFORT (Opus reasoning effort): low | medium | high | xhigh | max
AUTO_CONTENT_TEXT_MODEL=
AUTO_CONTENT_QUESTION_MODEL=
AUTO_CONTENT_AUDIO_MODEL=
AUTO_CONTENT_VIDEO_RANK_MODEL=
AUTO_CONTENT_EFFORT=medium

# Text-to-Speech (audio explainer generation) — order tried: ElevenLabs → Google → Sarvam
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
GOOGLE_TTS_API_KEY=

# Sentry error monitoring (optional — leave blank to disable). When set, server
# errors and caught pipeline failures report to your Sentry project.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=


